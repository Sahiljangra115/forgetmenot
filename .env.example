LLM_API_KEY=sk-your-openai-key

# --- Required: encrypts each user's saved LLM API key at rest ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Backend refuses to start without this set to a non-default value.
LLM_ENCRYPTION_KEY=replace-with-a-generated-random-value

# COGNEE_BASE_URL=https://your-instance.cognee.ai
# COGNEE_API_KEY=ck-your-cognee-cloud-key

# OPENAI_API_KEY=sk-your-openai-key
# SUMMARY_MODEL=gpt-4o-mini
# MATCH_THRESHOLD=0.55
# RECALL_TTL=30
# COGNEE_CALL_TIMEOUT=45

# --- Razorpay (pricing section checkout, cards + UPI via Standard Checkout) ---
# Test-mode keys from https://dashboard.razorpay.com/app/keys. KEY_SECRET is
# server-only, never sent to the frontend; KEY_ID is returned per-order to
# the browser (it's not secret, that's how Razorpay Checkout is meant to work).
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google OAuth (login page "Continue with Google") ---
# From https://console.cloud.google.com/apis/credentials. Without these the
# login page just disables the Google button instead of erroring.
# GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- local model instead of OpenAI (e.g. Ollama serving gemma) ---
# Cognee's own memory calls (remember/recall/forget) don't need this at all
# when running on Cognee Cloud -- that's handled server-side. This only
# affects this app's own one_liner()/distill()/transcribe() calls in llm.py.
# LLM_BASE_URL=http://localhost:11434/v1
# SUMMARY_MODEL=gemma3          # must match a tag from `ollama list` exactly
# If your model has a "-nothink"/"-instruct" variant, prefer it over the
# reasoning/"thinking" default: thinking variants put the real answer in a
# separate `reasoning` field and burn the whole max_tokens budget on
# internal thinking, so `message.content` (what this app reads) comes back
# empty. Verified with gemma4:e2b vs gemma4-e2b-nothink -- confirmed exactly
# this failure mode via a direct call to Ollama's API.
# transcribe() (Whisper) will NOT work against Ollama -- no STT endpoint --
# it fails closed to the existing 422 fallback, no crash.
